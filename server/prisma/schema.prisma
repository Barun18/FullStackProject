generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id      Int    @id @default(autoincrement())
  price   Float
  title   String
  img     String @db.Text
  review  String
  rating  Float
  type    String
  details Json
  categoryId Int
  category Category @relation(fields: [categoryId], references: [id])
}
model Category {
   id Int @id @default(autoincrement())
   name String @unique
   products Product[]
}
